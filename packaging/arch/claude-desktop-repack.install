post_install() {
  # Re-assert the setuid sandbox helper (root:root 4755) in case it was lost.
  chmod 4755 /usr/lib/claude-desktop/chrome-sandbox 2>/dev/null || true
  update-desktop-database -q 2>/dev/null || true
  gtk-update-icon-cache -q /usr/share/icons/hicolor 2>/dev/null || true
}

post_upgrade() {
  post_install
}

post_remove() {
  update-desktop-database -q 2>/dev/null || true
  gtk-update-icon-cache -q /usr/share/icons/hicolor 2>/dev/null || true
}

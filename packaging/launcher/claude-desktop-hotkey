#!/usr/bin/env bash
# Toggle Claude Desktop's Quick Entry from a keybinding, bypassing the broken
# GNOME Wayland GlobalShortcuts portal (electron/electron#51875). The app-side
# socket is added by the quick-entry-cli-toggle patch.
#
# This is a separate helper: the upstream /usr/bin/claude-desktop launcher is
# left completely untouched, so a bug here can never stop the app from starting.
#
#   claude-desktop-hotkey              toggle Quick Entry (open/close)
#   claude-desktop-hotkey --install    bind a GNOME shortcut to this command
#   claude-desktop-hotkey --uninstall  remove that shortcut

SOCK="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/claude-desktop-qe.sock"
ACCEL="${CLAUDE_QE_ACCEL:-<Control><Alt>space}"
GS_ROOT="org.gnome.settings-daemon.plugins.media-keys"
GS_KB="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/claude-desktop-quick-entry/"

toggle() {
  # Fast path: a connection to the running app's socket toggles in ~5-25 ms.
  if [ -S "$SOCK" ]; then
    if command -v socat >/dev/null 2>&1; then
      socat -u OPEN:/dev/null "UNIX-CONNECT:$SOCK" >/dev/null 2>&1 && exit 0
    fi
    if command -v python3 >/dev/null 2>&1; then
      python3 -c 'import socket,sys
s=socket.socket(socket.AF_UNIX); s.settimeout(0.5); s.connect(sys.argv[1]); s.close()' "$SOCK" >/dev/null 2>&1 && exit 0
    fi
  fi
  # Not running (or no socat/python): let the app handle --toggle in argv via its
  # cold-start / second-instance check. Uses the untouched upstream launcher.
  exec claude-desktop --toggle
}

install_hotkey() {
  command -v gsettings >/dev/null 2>&1 || { echo "gsettings not found (GNOME only)" >&2; exit 1; }
  local cur
  cur=$(gsettings get "$GS_ROOT" custom-keybindings 2>/dev/null)
  case "$cur" in
    *"$GS_KB"*) : ;;
    ""|"@as []"|"[]") gsettings set "$GS_ROOT" custom-keybindings "['$GS_KB']" ;;
    *) gsettings set "$GS_ROOT" custom-keybindings "${cur%]}, '$GS_KB']" ;;
  esac
  gsettings set "${GS_ROOT}.custom-keybinding:${GS_KB}" name 'Claude Quick Entry'
  gsettings set "${GS_ROOT}.custom-keybinding:${GS_KB}" command 'claude-desktop-hotkey'
  gsettings set "${GS_ROOT}.custom-keybinding:${GS_KB}" binding "$ACCEL"
  echo "Installed GNOME hotkey: $ACCEL -> claude-desktop-hotkey"
}

uninstall_hotkey() {
  command -v gsettings >/dev/null 2>&1 || exit 0
  local cur
  cur=$(gsettings get "$GS_ROOT" custom-keybindings 2>/dev/null)
  case "$cur" in *"$GS_KB"*)
    gsettings reset-recursively "${GS_ROOT}.custom-keybinding:${GS_KB}" 2>/dev/null || true
    gsettings set "$GS_ROOT" custom-keybindings \
      "$(printf '%s' "$cur" | sed "s#, '$GS_KB'##; s#'$GS_KB', ##; s#\['$GS_KB'\]#@as []#")"
  ;; esac
  echo "Removed GNOME hotkey."
}

case "${1:-}" in
  ""|--toggle|--toggle-quick-entry)      toggle ;;
  --install|--install-gnome-hotkey)      install_hotkey ;;
  --uninstall|--uninstall-gnome-hotkey)  uninstall_hotkey ;;
  *) echo "usage: claude-desktop-hotkey [--install|--uninstall]" >&2; exit 2 ;;
esac
